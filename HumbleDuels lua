        task.delay(1.5, function() savePBtn.Text = "+ Save Preset" end)
        return
    end
    local found = false
    for i, p in ipairs(Presets) do
        if p.name == nm then
            Presets[i].data = buildPresetSnapshot()
            found = true
            break
        end
    end
    if not found then
        table.insert(Presets, {name=nm, data=buildPresetSnapshot()})
    end
    savePresetsFile()
    presetNameBox.Text = ""
    savePBtn.Text = "✓ Saved!"
    task.delay(1.5, function() savePBtn.Text = "+ Save Preset" end)
